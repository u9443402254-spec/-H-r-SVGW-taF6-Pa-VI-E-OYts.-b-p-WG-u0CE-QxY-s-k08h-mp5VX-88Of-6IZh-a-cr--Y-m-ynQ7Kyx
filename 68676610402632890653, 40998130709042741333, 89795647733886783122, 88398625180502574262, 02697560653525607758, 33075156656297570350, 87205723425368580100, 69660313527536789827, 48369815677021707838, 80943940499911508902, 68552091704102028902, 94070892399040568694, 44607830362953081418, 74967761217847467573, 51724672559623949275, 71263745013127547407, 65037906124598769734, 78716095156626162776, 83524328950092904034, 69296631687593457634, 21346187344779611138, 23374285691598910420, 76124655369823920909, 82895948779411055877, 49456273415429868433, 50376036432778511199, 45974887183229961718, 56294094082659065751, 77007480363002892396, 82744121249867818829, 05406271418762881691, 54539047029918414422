local function apTh(t)
    T.bg=t.bg;T.bgS=t.bS;T.bgT=t.bT;T.ac=t.ac;T.bd=t.bd;T.off=t.of
    T.tx=t.tx;T.txM=t.tM;T.txD=t.tD
