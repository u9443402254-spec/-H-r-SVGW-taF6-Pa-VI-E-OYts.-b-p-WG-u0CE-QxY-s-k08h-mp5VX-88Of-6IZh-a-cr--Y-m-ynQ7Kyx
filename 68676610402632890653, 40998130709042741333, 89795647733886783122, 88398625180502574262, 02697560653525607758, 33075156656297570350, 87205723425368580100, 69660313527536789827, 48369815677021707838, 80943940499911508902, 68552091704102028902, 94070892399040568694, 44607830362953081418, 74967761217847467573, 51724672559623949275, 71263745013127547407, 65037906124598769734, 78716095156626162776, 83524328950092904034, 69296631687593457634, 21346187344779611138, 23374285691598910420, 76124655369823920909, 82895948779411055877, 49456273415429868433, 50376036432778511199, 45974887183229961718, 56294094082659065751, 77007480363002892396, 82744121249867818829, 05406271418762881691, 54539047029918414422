    for _,d in pairs(vGetDescendants()) do if dIsA(BasePart) and d.Name~=Handle then local m=d.Size.Magnitude;if mbm then best,bm=d,m end end end
    return best
end
local function pivMap()
    local r={};local gs=workspaceFindFirstChild(Game Systems);if not gs then return r end
    for _,wn in ipairs(VWS) do local f=gsFindFirstChild(wn);if not f then continue end
        for _,v in pairs(fGetChildren()) do for _,p in pairs(PlayersGetPlayers()) do if p~=plr and p.Character then
